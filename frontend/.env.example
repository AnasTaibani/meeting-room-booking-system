# Frontend environment configuration — Metamorphosys Room Booking
#
# Copy to .env and fill in real values for each environment.
# Variables prefixed with REACT_APP_ are inlined at build time.

# Backend base URL. The app calls `${REACT_APP_BACKEND_URL}/api/...`.
# Local:        http://localhost:8001
# Production:   https://your-api.onrender.com
REACT_APP_BACKEND_URL="http://localhost:8001"

# Disable noisy CRA file watchers in some sandboxes (optional)
WDS_SOCKET_PORT=443
