# Backend environment configuration — Metamorphosys Room Booking
#
# Copy to .env and fill in real values for each environment.
# DO NOT commit real secrets.

# --- MongoDB ---
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL="mongodb://localhost:27017"
DB_NAME="meeting_room_booking"

# --- Auth ---
# Generate a 64+ char random string:  python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET="change-me-to-a-long-random-string"

# --- Seed credentials (idempotent — only created once if missing) ---
ADMIN_EMAIL="admin@company.com"
ADMIN_PASSWORD="admin123"

# --- CORS ---
# Comma-separated list of allowed origins. Production example:
# CORS_ORIGINS="https://your-app.vercel.app,https://your-app-staging.vercel.app"
CORS_ORIGINS="http://localhost:3000"

# Single-origin fallback if you don't want to use CORS_ORIGINS
FRONTEND_URL="http://localhost:3000"

# --- Cookie behaviour ---
# Local dev:      COOKIE_SAMESITE=lax  COOKIE_SECURE=auto  (resolves to false)
# Production:     COOKIE_SAMESITE=none COOKIE_SECURE=true  (required for Vercel↔Render)
COOKIE_SAMESITE="lax"
COOKIE_SECURE="auto"
